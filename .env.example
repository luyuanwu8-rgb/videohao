# --- 抖音解析 (TikHub 付费 API) ---
TIKHUB_API_KEY=
TIKHUB_BASE_URL=https://api.tikhub.io

# --- 改写/分析/分镜 (通用 LLM，OpenAI 兼容，可自由切换厂商) ---
# DeepSeek: https://api.deepseek.com  model=deepseek-chat
# OpenAI:   https://api.openai.com    model=gpt-4o
# Kimi:     https://api.moonshot.cn   model=moonshot-v1-8k
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat
# 可选：成本估算单价（每 1K token），留空则不计费
LLM_PRICE_IN_PER_1K=
LLM_PRICE_OUT_PER_1K=

# --- 逐字稿 ASR + 配音 TTS (StepFun 云) ---
STEPFUN_API_KEY=
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_ASR_MODEL=step-asr
STEPFUN_TTS_MODEL=step-tts-mini
STEPFUN_TTS_VOICE=cixingnansheng

# --- 批量生图 (gpt-image) ---
GPTIMAGE_API_KEY=
GPTIMAGE_BASE_URL=https://api.openai.com/v1
GPTIMAGE_MODEL=gpt-image-1

# --- 九宫格视觉归位 (豆包 Seed 多模态, 火山方舟 Ark) ---
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_VISION_MODEL=doubao-seed-1-6-251015

# --- 全局开关 ---
PIPELINE_MODE=mock
DEFAULT_TRACK=health

# --- 渲染缓存重定向（C 盘满时用，指向有空间的盘）---
# VIDEOHAO_NPM_CACHE=E:\Codex\.npm-cache
# VIDEOHAO_TMP=E:\Codex\.tmp
